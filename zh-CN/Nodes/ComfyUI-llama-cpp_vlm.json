{
    "llama_cpp_model_loader": {
        "title": "Llama-cpp 模型加载器",
        "description": "加载Llama-cpp视觉语言模型，支持多种模型格式和VRAM限制配置",
        "inputs": {
            "model": "模型文件",
            "mmproj": "多模态投影文件",
            "chat_handler": "聊天处理器",
            "n_ctx": "上下文长度",
            "vram_limit": "VRAM限制",
            "image_min_tokens": "图像最小令牌数",
            "image_max_tokens": "图像最大令牌数"
        },
        "outputs": {
            "llama_model": "Llama模型配置"
        }
    },
    "llama_cpp_instruct_adv": {
        "title": "Llama-cpp 指令处理",
        "description": "高级指令处理节点，支持预设提示词、系统提示词、多种推理模式和状态管理",
        "inputs": {
            "llama_model": "Llama模型配置",
            "preset_prompt": "预设提示词",
            "custom_prompt": "自定义提示词",
            "system_prompt": "系统提示词",
            "inference_mode": "推理模式",
            "max_frames": "最大帧数",
            "max_size": "最大尺寸",
            "seed": "随机种子",
            "force_offload": "强制卸载",
            "save_states": "保存状态",
            "parameters": "参数配置",
            "images": "图像",
            "queue_handler": "队列处理器"
        },
        "outputs": {
            "output": "输出文本",
            "output_list": "输出列表",
            "state_uid": "状态ID"
        }
    },
    "llama_cpp_parameters": {
        "title": "Llama-cpp 参数配置",
        "description": "配置Llama-cpp推理参数，包括令牌限制、温度、惩罚等",
        "inputs": {
            "max_tokens": "最大令牌数",
            "top_k": "Top-K采样",
            "top_p": "Top-P采样",
            "min_p": "最小概率",
            "typical_p": "典型采样",
            "temperature": "温度",
            "repeat_penalty": "重复惩罚",
            "frequency_penalty": "频率惩罚",
            "presence_penalty": "存在惩罚",
            "mirostat_mode": "Mirostat模式",
            "mirostat_eta": "Mirostat ETA",
            "mirostat_tau": "Mirostat Tau",
            "state_uid": "状态ID"
        },
        "outputs": {
            "parameters": "参数配置"
        }
    },
    "llama_cpp_unload_model": {
        "title": "Llama-cpp 卸载模型",
        "description": "卸载当前加载的Llama-cpp模型以释放VRAM",
        "inputs": {
            "any": "任意输入"
        },
        "outputs": {
            "any": "任意输出"
        }
    },
    "llama_cpp_clean_states": {
        "title": "Llama-cpp 清除状态",
        "description": "清除保存的对话状态",
        "inputs": {
            "any": "任意输入",
            "state_uid": "状态ID"
        },
        "outputs": {
            "any": "任意输出"
        }
    },
    "parse_json_node": {
        "title": "解析JSON",
        "description": "解析JSON字符串并提取指定键的值",
        "inputs": {
            "input": "输入JSON",
            "key": "键名",
            "default": "默认值"
        },
        "outputs": {
            "any": "任意类型",
            "string": "字符串",
            "int": "整数",
            "float": "浮点数",
            "boolean": "布尔值"
        }
    },
    "json_to_bbox": {
        "title": "JSON转边界框",
        "description": "将JSON格式的边界框数据转换为BBOX格式",
        "inputs": {
            "json": "JSON字符串",
            "mode": "模式",
            "label": "标签过滤",
            "image": "图像"
        },
        "outputs": {
            "bboxes": "边界框列表",
            "image_list": "图像列表"
        }
    },
    "bbox_to_segs": {
        "title": "边界框转分割",
        "description": "将边界框转换为分割区域(SEGS)",
        "inputs": {
            "bboxes": "边界框",
            "image": "图像",
            "dilation": "膨胀",
            "feather": "羽化"
        },
        "outputs": {
            "segs": "分割区域"
        }
    },
    "bbox_to_mask": {
        "title": "边界框转掩码",
        "description": "将边界框转换为二值掩码",
        "inputs": {
            "bboxes": "边界框",
            "image": "图像",
            "dilation": "膨胀",
            "feather": "羽化"
        },
        "outputs": {
            "mask": "掩码"
        }
    },
    "bboxes_to_bbox": {
        "title": "边界框列表转单个边界框",
        "description": "从边界框列表中提取指定索引的边界框",
        "inputs": {
            "bboxes": "边界框列表",
            "image_index": "图像索引",
            "bbox_index": "边界框索引"
        },
        "outputs": {
            "bbox": "边界框"
        }
    },
    "remove_code_block": {
        "title": "移除代码块",
        "description": "从字符串中移除代码块标记",
        "inputs": {
            "input": "输入字符串",
            "label": "标签"
        },
        "outputs": {
            "output": "输出字符串"
        }
    },
    "PromptEnhancerPreset": {
        "title": "提示词增强预设",
        "description": "提供各种模型的预设系统提示词",
        "inputs": {
            "preset": "预设名称"
        },
        "outputs": {
            "system_prompt": "系统提示词"
        }
    }
